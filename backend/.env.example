# ZenTra Store Backend Environment Configuration

# Server Settings
PORT=8000
HOST=0.0.0.0

# Security (JWT)
# You can generate a new secret using: openssl rand -hex 32
JWT_SECRET_KEY=YOUR_SUPER_SECRET_JWT_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Primary SQL Server Database Configuration
# Format: mssql+pyodbc://<username>:<password>@<server>/<database>?driver=ODBC+Driver+17+for+SQL+Server
DATABASE_URL=mssql+pyodbc://@localhost/ZenTraDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Fallback Database (If SQL Server is unreachable, the system will fall back to SQLite for seamless testing)
SQLITE_FALLBACK_URL=sqlite:///./zentra_store.db

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880 # 5MB
